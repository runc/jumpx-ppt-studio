# 密钥 / 环境
.env
.env.local
**/.env
**/.env.local
!**/.env.example

# Python
backend/.venv/
__pycache__/
*.pyc
.langgraph_api/

# agent 工作区：复制进来的 skill + 各任务运行产物（可由 setup_workspace.py 重建）
backend/workspace/

# Node / UI
ui/node_modules/
ui/.next/
node_modules/

# vendor 参考仓库（只读，不纳入版本控制）
vendor/

# Cloudflare 部署构建产物（可由 esbuild 重建）
demo-dist/
.wrangler/

# 内部私有资料（本地路径 / 联系方式 / 项目背景），永不上传
_local/

# 系统
.DS_Store

# vendored 的 deep-agents-ui clone（自带 .git，可重新 clone）
ui/

# 前端构建
frontend/app/node_modules/
frontend/app/dist/
frontend/app/.vite/

# 导出方案调研：外部 repo 浅克隆，不入库
.export-research/
