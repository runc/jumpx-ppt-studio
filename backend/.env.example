# 复制为 .env 并填入真实值。.env 已被 .gitignore 拦截。
# 模型：OpenAI 兼容端点（当前用火山引擎方舟 Volcengine Ark）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_API_KEY=ark-xxxxxxxx
ARK_MODEL=ark-code-latest

# 图片生成 backend（出图路径用，HTML 路径不需要）
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# NANOBANANA_API_KEY=

# 多模态视觉模型（风格识别用）
ARK_VISION_MODEL=Doubao-Seed-2.0-lite

# 部署形态（「⚙ 模型能力」配置页行为）：
#   local  = 自托管/单机（默认）：可把 key 存到本机持久卷（0600）
#   shared = 公开/多租户：后端拒绝存 key，只接受请求级临时 key、用完即弃
#   ⚠️ 对外公开站（如 ai-ppt-studio.jumpxai.com）必须设为 shared
# STUDIO_TENANCY=local
