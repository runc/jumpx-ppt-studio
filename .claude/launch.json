{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ui",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["--cwd", "ui", "dev", "--port", "3002"],
      "port": 3002
    },
    {
      "name": "static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4180"],
      "port": 4180
    },
    {
      "name": "app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend/app", "run", "dev"],
      "port": 5180
    }
  ]
}
